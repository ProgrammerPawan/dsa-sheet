# Server
NODE_ENV=development
# 5050 avoids macOS AirPlay often binding :5000; if you use another PORT, set VITE_API_URL and apps/client/vite.config.ts proxy target to match.
PORT=5050
MONGO_URI=mongodb://localhost:27017/dsa-sheet
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Client
VITE_API_URL=http://localhost:5050/api
